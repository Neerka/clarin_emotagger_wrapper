# CLARIN Emotagger Configuration Example
# Copy this file to your environment and customize values

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Enable/disable Emotagger pre-processing pipeline
CLARIN_EMOTAGGER_ENABLED=true

# CLARIN LPMN services base URL
CLARIN_EMOTAGGER_BASE_URL=https://services.clarin-pl.eu/api/v1

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Path to CLARIN config.yml with credentials
# If not set, falls back to ~/.clarin/config.yml
# 
# config.yml format:
# USERNAME: your_escience_username
# PASSWORD: your_escience_password
# (or use API_TOKEN if available)
#
# CLARIN_EMOTAGGER_CONFIG_FILE=~/.clarin/config.yml

# ============================================================================
# TIMEOUT & RETRY
# ============================================================================

# Emotagger request timeout in seconds (5-300)
CLARIN_EMOTAGGER_TIMEOUT_SECONDS=30

# Maximum retries for transient errors (0-3)
CLARIN_EMOTAGGER_MAX_RETRIES=1

# Delay between retries in seconds (0.1-10.0)
CLARIN_EMOTAGGER_RETRY_DELAY_SECONDS=0.5

# ============================================================================
# INPUT VALIDATION
# ============================================================================

# Maximum text length for analysis (chars); longer texts are truncated
CLARIN_EMOTAGGER_MAX_TEXT_LENGTH=5000

# Minimum text length for analysis (chars); shorter texts return neutral
CLARIN_EMOTAGGER_MIN_TEXT_LENGTH=1

# ============================================================================
# FALLBACK BEHAVIOR (when Emotagger unavailable)
# ============================================================================

# Default emotion label on fallback
CLARIN_EMOTAGGER_FALLBACK_EMOTION_LABEL=neutral

# Default confidence score on fallback (0.0-1.0)
CLARIN_EMOTAGGER_FALLBACK_CONFIDENCE=0.0

# ============================================================================
# LOGGING & OBSERVABILITY
# ============================================================================

# Log Emotagger requests/responses (set to false in production for privacy)
CLARIN_EMOTAGGER_LOG_REQUESTS=false
